# SQLite file for local dev. For production use a Postgres URL and switch
# the provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Stripe (test mode). Leave STRIPE_SECRET_KEY empty to fall back to the
# built-in "demo payment" flow (auto-confirms orders, no real card charged).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Public URL of the web app, used to build Stripe redirect URLs.
WEB_APP_URL="http://localhost:3000"

PORT=4000
