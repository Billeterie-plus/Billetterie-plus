# URL de connexion PostgreSQL. Sur Railway/Render, cette variable est
# fournie automatiquement quand vous ajoutez une base Postgres au projet.
# Pour du dev 100% local sans service externe, une alternative est de
# repasser provider = "sqlite" dans prisma/schema.prisma et d'utiliser
# DATABASE_URL="file:./dev.db".
DATABASE_URL="postgresql://user:password@localhost:5432/billetterie"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Stripe (test mode). Leave STRIPE_SECRET_KEY empty to fall back to the
# built-in "demo payment" flow (auto-confirms orders, no real card charged).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Public URL of the web app, used to build Stripe redirect URLs.
WEB_APP_URL="http://localhost:3000"

# Resend (resend.com) — utilisé pour l'email "mot de passe oublié". Laissez
# vide pour simuler l'envoi (le contenu de l'email est juste affiché dans les
# logs du serveur, pratique en développement).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Ticket Area <onboarding@resend.dev>"

PORT=4000
